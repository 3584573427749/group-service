{
  "name": "simning.ax/auth_service",
  "description": "User management backend service",
  "license": "MIT",
  "type": "project",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "infection/extension-installer": true,
      "phpro/grumphp": true
    }
  },
  "require": {
    "php": "^8.5",
    "slim/slim": "^4.15",
    "php-di/php-di": "^7.1",
    "slim/psr7": "^1.8",
    "doctrine/dbal": "^4.4",
    "robmorgan/phinx": "^0.16",
    "monolog/monolog": "^3.10",
    "vlucas/phpdotenv": "^5.6",
    "ramsey/uuid": "^4.9"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5",
    "phpstan/phpstan": "^2.2",
    "friendsofphp/php-cs-fixer": "^3.95",
    "squizlabs/php_codesniffer": "^4.0",
    "infection/infection": "^0.34.0",
    "rector/rector": "^2.4",
    "phpro/grumphp": "^2.21",
    "league/openapi-psr7-validator": "^0.24.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "@php -r \"if (!is_dir('.ci')) mkdir('.ci', 0777, true); if (!file_exists('.ci/php-service')) touch('.ci/php-service'); if (!file_exists('.ci/dockerdeploy')) touch('.ci/dockerdeploy');\""
    ],
    "up": "docker compose up --build",
    "down": "docker compose down",
    "start": "docker compose up",
    "shell": "docker compose exec slim-service sh",
    "logs": "docker compose logs -f",
    "test": "vendor/bin/phpunit",
    "stan": "vendor/bin/phpstan analyse src tests --level=7 --memory-limit=1G",
    "cs-fix": "vendor/bin/php-cs-fixer fix",
    "cs-fix:check": "vendor/bin/php-cs-fixer fix --dry-run --diff",
    "lint": "vendor/bin/phpcs src tests",
    "migrate": "vendor/bin/phinx migrate",
    "rollback": "vendor/bin/phinx rollback",
    "openapi:validate": "php ./bin/validate-openapi.php"
  }
}
